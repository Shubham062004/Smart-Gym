generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String    @id @default(uuid())
  name           String
  email          String    @unique
  password_hash  String
  age            Int?
  height         Float?
  weight         Float?
  fitness_goal   String?
  otp_code       String?
  otp_expires_at DateTime?
  created_at     DateTime  @default(now())
}
